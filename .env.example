# MongoDB — full Atlas connection string (must start with mongodb+srv:// or mongodb://)
# Do not wrap in quotes in Vercel. Example:
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
#
# PERSISTENCE: Runs, builds, leaderboards, and user links live in MongoDB — not on the Vercel app.
# Redeploys do NOT wipe this data. Keep MONGODB_URI and MONGODB_DB_NAME stable across deploys.
# Changing either env var points the app at a different (possibly empty) database.
MONGODB_URI=
MONGODB_DB_NAME=destinytopnest

# Session JWT — use a long random string; JWT_SECRET is an alias
SESSION_SECRET=
JWT_SECRET=

# Site URL (production OAuth redirects)
NEXT_PUBLIC_BASE_URL=https://topnest.app

# Bungie API + OAuth (primary login)
DESTINY_API=
BUNGIE_API_KEY=
BUNGIE_OAUTH_CLIENT_ID=
BUNGIE_OAUTH_CLIENT_SECRET=
BUNGIE_OAUTH_REDIRECT_URI=https://topnest.app/api/destiny/auth/bungie/callback

# Primary owner allowlist (comma-separated Bungie names or handles).
# Defaults to Bulletbait604#0950 when unset. Only this account can grant/revoke other admins.
OWNER_USERNAMES=

# Optional — Google AI (future meta research / Gemini features; not required today)
# Aliases used elsewhere in the monorepo: GEMINI_API, GOOGLE_API_KEY
GOOGLE_API=
GEMINI_API=

# Optional cookie hardening in production
# SESSION_COOKIE_SECURE=true
