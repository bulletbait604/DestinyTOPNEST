# MongoDB — full Atlas connection string (must start with mongodb+srv:// or mongodb://)
# Do not wrap in quotes in Vercel. Example:
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB_NAME=destinytopnest

# Session (Kick login) — use a long random string; JWT_SECRET is an alias
SESSION_SECRET=
JWT_SECRET=

# Kick OAuth
NEXT_PUBLIC_KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
NEXT_PUBLIC_KICK_REDIRECT_URI=http://localhost:3000/auth/kick/callback

# Site URL (production OAuth redirects)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Bungie API + OAuth
DESTINY_API=
BUNGIE_API_KEY=
BUNGIE_OAUTH_CLIENT_ID=
BUNGIE_OAUTH_CLIENT_SECRET=
BUNGIE_OAUTH_REDIRECT_URI=http://localhost:3000/api/destiny/auth/bungie/callback

# Admin / staff (comma-separated Kick usernames)
OWNER_USERNAMES=

# Optional server-to-server guard
INTERNAL_API_SECRET=

# Optional — Google AI (future meta research / Gemini features; not required today)
# Aliases used elsewhere in the monorepo: GEMINI_API, GOOGLE_API_KEY
GOOGLE_API=
GEMINI_API=

# Optional cookie hardening in production
# SESSION_COOKIE_SECURE=true
